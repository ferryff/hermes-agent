#!/command/with-contenv sh
# Bootstrap /opt/data config and credentials for Railway deployment.
# Runs as root after stage2-hook has seeded the volume.
# Always overwrites config.yaml (seeded from example above; we need Railway values).

set -e

DATA=/opt/data

# ── config.yaml ──────────────────────────────────────────────────────────────
cat > "$DATA/config.yaml" << 'YAMLEOF'
model:
  default: gemini/gemini-2.5-pro
  provider: google
auxiliary:
  compression:
    provider: auto
    model: gemini/gemini-2.5-flash
  web_extract:
    provider: auto
    model: gemini/gemini-2.5-flash
  approval:
    provider: auto
    model: gemini/gemini-2.5-flash
  title_generation:
    provider: auto
    model: gemini/gemini-2.5-flash
agent:
  max_turns: 20
  gateway_timeout: 1800
  reasoning_effort: low
terminal:
  backend: local
  env_passthrough:
    - NOTION_API_KEY
    - GOOGLE_API_KEY
    - ANTHROPIC_API_KEY
    - GMAIL_CLIENT_ID
    - GMAIL_CLIENT_SECRET
    - GMAIL_REFRESH_TOKEN
approvals:
  mode: manual
  cron_mode: auto
telegram:
  reactions: false
  channel_prompts: {}
  allowed_chats: "${TELEGRAM_ALLOWED_USERS}"
mcp_servers:
  notion:
    command: npx
    args:
      - -y
      - "@notionhq/notion-mcp-server@1.9.1"
    env:
      OPENAPI_MCP_HEADERS: '{"Authorization": "Bearer ${NOTION_API_KEY}", "Notion-Version": "2022-06-28"}'
  gmail_autoauth:
    command: npx
    args:
      - -y
      - "@gongrzhe/server-gmail-autoauth-mcp"
    enabled: true
dashboard:
  basic_auth:
    username: ferry
    password: "${HERMES_DASHBOARD_PASSWORD}"
    secret: "${HERMES_DASHBOARD_SECRET}"
_config_version: 29
YAMLEOF
chown hermes:hermes "$DATA/config.yaml"
chmod 640 "$DATA/config.yaml"
echo "[railway-bootstrap] Wrote $DATA/config.yaml"

# ── SOUL.md — always refresh from image (router soul in docker/SOUL.md) ──────
cp /opt/hermes/docker/SOUL.md "$DATA/SOUL.md"
chown hermes:hermes "$DATA/SOUL.md"
echo "[railway-bootstrap] Refreshed SOUL.md from docker/SOUL.md"

# ── Gmail MCP credentials (write once; OAuth refresh may update them) ─────────
GMAIL_DIR="$DATA/.gmail-mcp"
MARKER="$DATA/.railway-gmail-seeded"
if [ -n "${GMAIL_CLIENT_ID}" ] && [ ! -f "$MARKER" ]; then
  mkdir -p "$GMAIL_DIR"
  cat > "$GMAIL_DIR/gcp-oauth.keys.json" << JSONEOF
{"installed":{"client_id":"${GMAIL_CLIENT_ID}","client_secret":"${GMAIL_CLIENT_SECRET}","redirect_uris":["http://localhost"],"auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}}
JSONEOF
  cat > "$GMAIL_DIR/credentials.json" << JSONEOF
{"refresh_token":"${GMAIL_REFRESH_TOKEN}"}
JSONEOF
  chown -R hermes:hermes "$GMAIL_DIR"
  touch "$MARKER"
  chown hermes:hermes "$MARKER"
  echo "[railway-bootstrap] Wrote Gmail MCP credentials"
fi

# ── System packages ───────────────────────────────────────────────────────────
apt-get install -y -q poppler-utils 2>&1 | tail -2
echo "[railway-bootstrap] poppler-utils installed"

# ── qmd: install on every start, embed only once ─────────────────────────────
QMD_MARKER="$DATA/.railway-qmd-seeded"
KNOWLEDGE_SRC="/opt/hermes/knowledge"
KNOWLEDGE_DST="$DATA/knowledge"
QMD_CACHE="$DATA/qmd-cache"

# Always reinstall qmd — binary lives in the container, not the Volume
npm install -g @tobilu/qmd 2>&1 | tail -3
echo "[railway-bootstrap] qmd installed"

# Pre-warm the embedding model — runs on every start so first Felix query is fast
# Uses a dummy query; model downloads to container cache (~60s on cold start, instant after)
su -s /bin/sh hermes -c "
  export QMD_CACHE_DIR=$QMD_CACHE
  export HOME=/opt/data
  timeout 120 qmd query 'warmup habits' >/dev/null 2>&1 || true
"
echo "[railway-bootstrap] qmd model warm"

if [ ! -f "$QMD_MARKER" ]; then
  echo "[railway-bootstrap] Setting up qmd knowledge base (first time)..."

  # Copy knowledge markdown files from image to Volume
  mkdir -p "$KNOWLEDGE_DST"
  cp "$KNOWLEDGE_SRC"/*.md "$KNOWLEDGE_DST/"
  chown -R hermes:hermes "$KNOWLEDGE_DST"

  # Point qmd cache to Volume so index survives redeploys
  mkdir -p "$QMD_CACHE"

  # Add collection and embed (runs as hermes user to own the index)
  su -s /bin/sh hermes -c "
    export QMD_CACHE_DIR=$QMD_CACHE
    export HOME=/opt/data
    qmd collection add $KNOWLEDGE_DST --name coaching-books
    qmd context add qmd://coaching-books 'Books on habits, focus, and personal performance for coaching'
    qmd embed
  "

  chown -R hermes:hermes "$QMD_CACHE"
  touch "$QMD_MARKER"
  chown hermes:hermes "$QMD_MARKER"
  echo "[railway-bootstrap] qmd knowledge base ready"
else
  echo "[railway-bootstrap] qmd already seeded, skipping embed"
fi

# ── Coach cron jobs — disabled ────────────────────────────────────────────────
# Coach crons removed. Finance daily summary is seeded below.

# ── Finance cron jobs (seed once) ─────────────────────────────────────────────
FINANCE_CRON_MARKER="$DATA/.railway-finance-cron-seeded"

if [ ! -f "$FINANCE_CRON_MARKER" ]; then
  echo "[railway-bootstrap] Seeding Finance cron jobs..."
  mkdir -p "$DATA/cron"
  NOW=$(date -u +"%Y-%m-%dT%H:%M:%S.000000+00:00")

  # Merge finance job into existing jobs.json
  python3 - << 'PYEOF'
import json, os

CRON_FILE = "/opt/data/cron/jobs.json"
NOW = os.popen("date -u +'%Y-%m-%dT%H:%M:%S.000000+00:00'").read().strip()

finance_job = {
  "id": "finance-daily-summary",
  "name": "Finance Daily Summary",
  "prompt": "Today is $(date +'%d %B %Y'). Run the finance skill daily summary: query today's expenses and month-to-date total from Notion. Send to Telegram using the format: no spending → 'No spending logged today ✓\\nMonth so far: $XX.XX', has spending → list each transaction as '{card} — {merchant} ${amount}' then 'Total today: $XX.XX\\nMonth so far: $XX.XX'.",
  "skills": ["finance", "spending-tracker"],
  "skill": "finance",
  "model": None,
  "provider": None,
  "base_url": None,
  "script": None,
  "no_agent": False,
  "context_from": None,
  "schedule": {"kind": "cron", "expr": "0 14 * * *", "display": "0 14 * * *"},
  "schedule_display": "0 14 * * *",
  "repeat": {"times": None, "completed": 0},
  "enabled": True,
  "state": "scheduled",
  "paused_at": None,
  "paused_reason": None,
  "created_at": NOW,
  "next_run_at": None,
  "last_run_at": None,
  "last_status": None,
  "last_error": None,
  "last_delivery_error": None,
  "deliver": "telegram",
  "origin": None,
  "enabled_toolsets": None,
  "workdir": None
}

if os.path.exists(CRON_FILE):
  with open(CRON_FILE) as f:
    data = json.load(f)
  jobs = data.get("jobs", [])
  # Remove existing finance-daily-summary if present (idempotent)
  jobs = [j for j in jobs if j.get("id") != "finance-daily-summary"]
  jobs.append(finance_job)
  data["jobs"] = jobs
  data["updated_at"] = NOW
else:
  data = {"jobs": [finance_job], "updated_at": NOW}

with open(CRON_FILE, "w") as f:
  json.dump(data, f, indent=2)
print("[railway-bootstrap] Finance daily summary cron added")
PYEOF

  chown hermes:hermes "$CRON_FILE"
  touch "$FINANCE_CRON_MARKER"
  chown hermes:hermes "$FINANCE_CRON_MARKER"
  echo "[railway-bootstrap] Finance cron jobs seeded"
else
  echo "[railway-bootstrap] Finance cron already seeded, skipping"
fi