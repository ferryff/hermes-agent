#!/command/with-contenv sh
# Bootstrap /opt/data config and credentials for Railway deployment.
# Runs as root after stage2-hook has seeded the volume.
# Always overwrites config.yaml (seeded from example above; we need Railway values).

set -e

DATA=/opt/data

# ── config.yaml ──────────────────────────────────────────────────────────────
cat > "$DATA/config.yaml" << 'YAMLEOF'
model:
  default: gemini/gemini-2.5-pro
  provider: google
agent:
  max_turns: 60
  gateway_timeout: 1800
  reasoning_effort: medium
terminal:
  backend: local
  env_passthrough:
    - NOTION_API_KEY
    - GOOGLE_API_KEY
    - ANTHROPIC_API_KEY
    - GMAIL_CLIENT_ID
    - GMAIL_CLIENT_SECRET
    - GMAIL_REFRESH_TOKEN
approvals:
  mode: manual
  cron_mode: auto
telegram:
  reactions: false
  channel_prompts: {}
  allowed_chats: "${TELEGRAM_ALLOWED_USERS}"
mcp_servers:
  notion:
    command: npx
    args:
      - -y
      - "@notionhq/notion-mcp-server@1.9.1"
    env:
      OPENAPI_MCP_HEADERS: '{"Authorization": "Bearer ${NOTION_API_KEY}", "Notion-Version": "2022-06-28"}'
  gmail_autoauth:
    command: npx
    args:
      - -y
      - "@gongrzhe/server-gmail-autoauth-mcp"
    enabled: true
dashboard:
  basic_auth:
    username: ferry
    password: "${HERMES_DASHBOARD_PASSWORD}"
    secret: "${HERMES_DASHBOARD_SECRET}"
_config_version: 29
YAMLEOF
chown hermes:hermes "$DATA/config.yaml"
chmod 640 "$DATA/config.yaml"
echo "[railway-bootstrap] Wrote $DATA/config.yaml"

# ── SOUL.md — always refresh from image (router soul in docker/SOUL.md) ──────
cp /opt/hermes/docker/SOUL.md "$DATA/SOUL.md"
chown hermes:hermes "$DATA/SOUL.md"
echo "[railway-bootstrap] Refreshed SOUL.md from docker/SOUL.md"

# ── Gmail MCP credentials (write once; OAuth refresh may update them) ─────────
GMAIL_DIR="$DATA/.gmail-mcp"
MARKER="$DATA/.railway-gmail-seeded"
if [ -n "${GMAIL_CLIENT_ID}" ] && [ ! -f "$MARKER" ]; then
  mkdir -p "$GMAIL_DIR"
  cat > "$GMAIL_DIR/gcp-oauth.keys.json" << JSONEOF
{"installed":{"client_id":"${GMAIL_CLIENT_ID}","client_secret":"${GMAIL_CLIENT_SECRET}","redirect_uris":["http://localhost"],"auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}}
JSONEOF
  cat > "$GMAIL_DIR/credentials.json" << JSONEOF
{"refresh_token":"${GMAIL_REFRESH_TOKEN}"}
JSONEOF
  chown -R hermes:hermes "$GMAIL_DIR"
  touch "$MARKER"
  chown hermes:hermes "$MARKER"
  echo "[railway-bootstrap] Wrote Gmail MCP credentials"
fi

# ── qmd: install on every start, embed only once ─────────────────────────────
QMD_MARKER="$DATA/.railway-qmd-seeded"
KNOWLEDGE_SRC="/opt/hermes/knowledge"
KNOWLEDGE_DST="$DATA/knowledge"
QMD_CACHE="$DATA/qmd-cache"

# Always reinstall qmd — binary lives in the container, not the Volume
npm install -g @tobilu/qmd 2>&1 | tail -3
echo "[railway-bootstrap] qmd installed"

if [ ! -f "$QMD_MARKER" ]; then
  echo "[railway-bootstrap] Setting up qmd knowledge base (first time)..."

  # Copy knowledge markdown files from image to Volume
  mkdir -p "$KNOWLEDGE_DST"
  cp "$KNOWLEDGE_SRC"/*.md "$KNOWLEDGE_DST/"
  chown -R hermes:hermes "$KNOWLEDGE_DST"

  # Point qmd cache to Volume so index survives redeploys
  mkdir -p "$QMD_CACHE"

  # Add collection and embed (runs as hermes user to own the index)
  su -s /bin/sh hermes -c "
    export QMD_CACHE_DIR=$QMD_CACHE
    export HOME=/opt/data
    qmd collection add $KNOWLEDGE_DST --name coaching-books
    qmd context add qmd://coaching-books 'Books on habits, focus, and personal performance for coaching'
    qmd embed
  "

  chown -R hermes:hermes "$QMD_CACHE"
  touch "$QMD_MARKER"
  chown hermes:hermes "$QMD_MARKER"
  echo "[railway-bootstrap] qmd knowledge base ready"
else
  echo "[railway-bootstrap] qmd already seeded, skipping embed"
fi

# ── Coach cron jobs (seed once) ───────────────────────────────────────────────
CRON_MARKER="$DATA/.railway-cron-seeded"
CRON_FILE="$DATA/cron/jobs.json"

if [ ! -f "$CRON_MARKER" ]; then
  echo "[railway-bootstrap] Seeding Coach cron jobs..."
  mkdir -p "$DATA/cron"
  cat > "$CRON_FILE" << 'CRONEOF'
[
  {
    "id": "coach-morning-gate",
    "name": "Coach Morning Gate",
    "schedule": "0 23 * * *",
    "prompt": "Run the coach skill morning gate: check for an active week program in Notion for the current ISO week. If found, send the 3-beat morning message. If not found, run the Monday check-in flow.",
    "skills": ["coach"],
    "deliver": "telegram",
    "enabled": true,
    "state": "scheduled"
  },
  {
    "id": "coach-evening-checkin",
    "name": "Coach Evening Check-in",
    "schedule": "0 12 * * *",
    "prompt": "Run the coach skill evening check-in: load the current week program cadence, check if today is a check-in day, and if so send one tailored question. Skip silently if not a check-in day.",
    "skills": ["coach"],
    "deliver": "telegram",
    "enabled": true,
    "state": "scheduled"
  },
  {
    "id": "coach-sunday-review",
    "name": "Coach Sunday Review",
    "schedule": "0 12 * * 0",
    "prompt": "Run the coach skill Sunday week-in-review: send a light reflection on the week's progress (one observation, one thing to carry into Monday), then mark the current week program Completed in Notion.",
    "skills": ["coach"],
    "deliver": "telegram",
    "enabled": true,
    "state": "scheduled"
  }
]
CRONEOF
  chown hermes:hermes "$CRON_FILE"
  touch "$CRON_MARKER"
  chown hermes:hermes "$CRON_MARKER"
  echo "[railway-bootstrap] Coach cron jobs seeded"
else
  echo "[railway-bootstrap] Cron jobs already seeded, skipping"
fi